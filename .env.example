# Copy to .env next to docker-compose.yml and fill in.

# Token for admin actions (submitting from the web form, retry/cancel,
# machine controls, creating nodes). Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DATA_INTAKE_ADMIN_TOKEN=change-me

# Push alerts via ntfy (https://ntfy.sh) — leave empty to disable.
# Subscribe to this topic in the ntfy phone app / browser to get alerts for
# failures, machines going offline, and finished projects. The topic name is
# the only credential (anyone who knows it can read the alerts), so keep it
# unguessable; regenerate your own with:
#   python -c "import secrets; print('data-intake-' + secrets.token_urlsafe(24))"
DATA_INTAKE_NTFY_TOPIC=data-intake-SaDBePF4O9p6XVDXaE6LmY12Y0Zh9aIZ

# Self-hosted ntfy server (optional; default is https://ntfy.sh).
#DATA_INTAKE_NTFY_SERVER=https://ntfy.sh
# Access token, only for a self-hosted server / reserved topic with auth.
#DATA_INTAKE_NTFY_TOKEN=
